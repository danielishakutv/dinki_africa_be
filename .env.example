# Dinki Backend Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=dinki
DB_USER=dinki_app
DB_PASSWORD=your_password_here

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Email
# Preferred: Resend (better inbox delivery). Set RESEND_API_KEY and the code
# sends via Resend automatically. Leave it unset to fall back to local Postfix.
# EMAIL_FROM must be an address on a domain you've VERIFIED in Resend.
RESEND_API_KEY=
EMAIL_FROM="Dinki Africa <no-reply@dinki.africa>"
EMAIL_SUPPORT=support@dinki.africa
# Postfix fallback (used only when RESEND_API_KEY is empty)
EMAIL_HOST=host.docker.internal

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=2097152
